{
  "name": "orchestrator",
  "displayName": "Orchestrator — AI Coding Team",
  "description": "Assemble a team of AI sub-agents (Claude, GPT, Gemini), assign skills, and run multi-stage handoff workflows that write code directly to your workspace.",
  "version": "0.0.1",
  "publisher": "sukronz",
  "repository": {
    "type": "git",
    "url": "https://github.com/sukronz/orchestrator.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "orchestrator.openControlPanel",
        "title": "Open Orchestrator Control Panel"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "orchestrator.openControlPanel",
          "when": "true"
        }
      ]
    }
  },
  "activationEvents": [
    "onCommand:orchestrator.openControlPanel"
  ],
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
